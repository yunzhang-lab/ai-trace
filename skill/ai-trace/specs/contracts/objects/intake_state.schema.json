{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Intake State",
  "type": "object",
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "skipped"
            ]
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "updated_at"
        ]
      }
    },
    "spaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "skipped"
            ]
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "updated_at"
        ]
      }
    }
  },
  "required": [
    "generated_at",
    "agents",
    "spaces"
  ]
}
